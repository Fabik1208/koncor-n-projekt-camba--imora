<Window x:Class="koncorčný_projekt_camba_šimora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TodoList — Welcome" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">
    <Window.Resources>
        <LinearGradientBrush x:Key="LeftGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4F46E5" Offset="0.0"/>
            <GradientStop Color="#7C3AED" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Branding / Illustration -->
        <Border Grid.Column="0" CornerRadius="12" Margin="24" Padding="32"
                Background="{StaticResource LeftGradientBrush}">
            <!-- Removed duplicate resource definition here -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,8,0,0">
                    <TextBlock Text="TodoList" FontSize="34" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Organize. Prioritize. Ship." Margin="0,6,0,0"
                               Foreground="#EDE9FE" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" >
                    <!-- Simple SVG-style task illustration using shapes -->
                    <Grid Width="220" Height="180" Margin="0,8,0,16">
                        <Rectangle RadiusX="12" RadiusY="12" Fill="#FFFFFF20"/>
                        <StackPanel Margin="18">
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Ellipse Width="18" Height="18" Fill="#34D399"/>
                                <TextBlock Text=" Buy groceries" Foreground="White" FontSize="14" Margin="8,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Ellipse Width="18" Height="18" Fill="#FBBF24"/>
                                <TextBlock Text=" Call Alice" Foreground="White" FontSize="14" Margin="8,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Ellipse Width="18" Height="18" Fill="#60A5FA"/>
                                <TextBlock Text=" Finish report" Foreground="White" FontSize="14" Margin="8,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Fast, simple, and powerful task management for individuals and teams."
                               TextWrapping="Wrap" Foreground="#EDE9FE" FontSize="13" TextAlignment="Center" Width="260"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT: Card with Login / Register -->
        <Grid Grid.Column="1" Margin="24">
            <Border CornerRadius="12" Background="White" Padding="28" Effect="{DynamicResource CardShadow}">
                <Border.Resources>
                    <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="6" Color="#33000000"/>
                    <Style x:Key="PrimaryButton" TargetType="Button">
                        <Setter Property="Background" Value="#4F46E5"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style x:Key="GhostButton" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#6B7280"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Margin" Value="0,6,0,6"/>
                        <Setter Property="Padding" Value="8"/>
                    </Style>
                    <Style TargetType="PasswordBox">
                        <Setter Property="Margin" Value="0,6,0,6"/>
                        <Setter Property="Padding" Value="8"/>
                    </Style>
                </Border.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header + Tabs -->
                    <!-- FIX: Use DockPanel for space-between effect -->
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Welcome back" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Sign in to access your tasks" FontSize="13" Foreground="#6B7280"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="12,0,0,0">
                            <Button x:Name="BtnLoginTab" Content="Login" Click="SwitchToLogin_Click" Style="{StaticResource GhostButton}"/>
                            <Button x:Name="BtnRegisterTab" Content="Register" Click="SwitchToRegister_Click" Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                    </DockPanel>

                    <Separator Grid.Row="1" Margin="0,12,0,12"/>

                    <!-- Forms -->
                    <Grid Grid.Row="2">
                        <Grid.Resources>
                            <Style x:Key="LabelStyle" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#374151"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Margin" Value="0,6,0,4"/>
                            </Style>
                        </Grid.Resources>

                        <Grid x:Name="LoginGrid">
                            <StackPanel>
                                <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="LoginEmail" Text="" />

                                <TextBlock Text="Password" Style="{StaticResource LabelStyle}" Margin="0,10,0,4"/>
                                <PasswordBox x:Name="LoginPassword"/>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10">
                                    <CheckBox x:Name="RememberMe" Content="Remember me" Foreground="#6B7280"/>
                                    <TextBlock Text=" " Width="12"/>
                                    
                                </StackPanel>

                                <Button Content="Sign in" Click="Login_Click" Style="{StaticResource PrimaryButton}" Margin="0,12,0,8" />

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6">
                                    <TextBlock Text="New here?" Foreground="#6B7280"/>
                                    <Button Content="Create account" Click="SwitchToRegister_Click" Style="{StaticResource GhostButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="RegisterGrid" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Full name" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RegName" Text="" />

                                <TextBlock Text="Email" Style="{StaticResource LabelStyle}" Margin="0,6,0,4"/>
                                <TextBox x:Name="RegEmail" Text="" />

                                <TextBlock Text="Password" Style="{StaticResource LabelStyle}" Margin="0,6,0,4"/>
                                <PasswordBox x:Name="RegPassword"/>

                                <TextBlock Text="Confirm password" Style="{StaticResource LabelStyle}" Margin="0,6,0,4"/>
                                <PasswordBox x:Name="RegConfirmPassword"/>

                                <Button Content="Create account" Click="Register_Click" Style="{StaticResource PrimaryButton}" Margin="0,12,0,8" />

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6">
                                    <TextBlock Text="Already have an account?" Foreground="#6B7280"/>
                                    <Button Content="Sign in" Click="SwitchToLogin_Click" Style="{StaticResource GhostButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
