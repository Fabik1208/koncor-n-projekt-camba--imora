<Window x:Class="koncorcny_projekt_camba_simora.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TodoList — Dashboard" Height="480" Width="800" WindowStartupLocation="CenterOwner" Background="#FFFFFF">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock x:Name="WelcomeText" FontSize="22" FontWeight="Bold" Margin="6"/>
            <TextBlock Text="This is a simple dashboard window opened after a successful login." Foreground="#6B7280" Margin="6"/>
            <Button Content="Sign out" Width="110" Margin="6" HorizontalAlignment="Left" Click="SignOut_Click"/>
        </StackPanel>
    </Grid>
</Window>